---
import "../styles/global.css";
---
<!doctype html>
<html lang="en" data-theme="light">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />

    <!-- Font preconnect + non-blocking load -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,600;0,700;1,400&display=swap" />

    <!-- Prefetch main pages -->
    <link rel="prefetch" href="/about/about" />
    <link rel="prefetch" href="/articles/articles" />
    <link rel="prefetch" href="/projects/projects" />
	</head>
	<body>
		<!-- 🌸 Background layer -->
		<div id="bg-root">
			<div class="bg-base">
			</div>
		</div>
		<div class="content">
      		<slot />
    	</div>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
	}
	/* root layer */
	:root {
	--bg-top: 200 220 255;     /* blue */
	--bg-bottom: 79 141 255; /*  249 250 251; near white */
	}
	#bg-root {
		position: fixed;
		inset: 0;
		z-index: -1;
		pointer-events: none;
	}

	/* base layer */
	.bg-base {
	position: absolute;
	inset: 0;
	background: white;
	/* background: linear-gradient(
		to bottom,
		rgb(var(--bg-top)),
		rgb(var(--bg-bottom))
	);
	transition: background 0.1s linear; */
	}


	.content {
		position: relative;
		min-height: 100vh;
		z-index: 1;
	}
</style>

<script>
  const root = document.documentElement;

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function updateBackground() {
    const scrollTop = window.scrollY;
    const maxScroll =
      document.body.scrollHeight - window.innerHeight;

    const t = Math.min(scrollTop / maxScroll, 1);

    // Cartoon Network blue → soft white
    const topColor = [
      lerp(79, 240, t),
      lerp(141, 242, t),
      lerp(255, 248, t),
    ];

    const bottomColor = [
      lerp(43, 249, t),
      lerp(111, 250, t),
      lerp(255, 251, t),
    ];

    root.style.setProperty(
      "--bg-top",
      topColor.map(v => Math.round(v)).join(" ")
    );

    root.style.setProperty(
      "--bg-bottom",
      bottomColor.map(v => Math.round(v)).join(" ")
    );
  }

  window.addEventListener("scroll", updateBackground);
  window.addEventListener("resize", updateBackground);

  updateBackground(); // run once on load
</script>
