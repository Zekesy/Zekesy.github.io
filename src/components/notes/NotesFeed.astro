---
import NoteCard from "../NoteCard.astro";
import type { CollectionEntry } from 'astro:content';
const { notes } = Astro.props;
---
<div id="notes-feed">
    <div class="feed-header">
        <h2>Latest Updates</h2>
        <p>Thoughts, projects, and everything in between</p>
    </div>

    <div class="feed-container" id="notes-container">
        {notes.map((note: CollectionEntry<'notes'>) => (
            <NoteCard entry={note} />
        ))}
    </div>
</div>

<style>
    #notes-feed {
        /* min-width: 0 is critical — without it the element ignores
           the grid column boundary and bleeds into the sidebar */
        min-width: 0;
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    .feed-header {
        padding: 16px 0 20px;
        border-bottom: 1px solid #e5e7eb;
    }

    .feed-header h2 {
        font-size: 1.25rem;
        font-weight: 700;
        margin: 0 0 4px;
        color: #111827;
    }

    .feed-header p {
        margin: 0;
        color: #6b7280;
        font-size: 0.875rem;
    }

    .feed-container {
        display: flex;
        flex-direction: column;
        gap: 5px;          /* let NoteCard handle its own bottom border/spacing */
    }
</style>
