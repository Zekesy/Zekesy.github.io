---
import { Image } from 'astro:assets';
import { render } from "astro:content";
import astroLogo from '../../assets/astro.svg';

const { entry } = Astro.props;
const { Content } = await render(entry);

const {
  avatar,
  pubDate,
  hashtags = [],
} = entry.data;

const formattedDate = pubDate.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<article class="tweet-card" data-note-id={entry.id}>
    <div class="tweet-content">
        <!-- Avatar -->
        <div class="avatar-container">
            <img 
                src={astroLogo.src} 
                alt="Zeke Sy profile" 
                class="avatar" 
                loading="lazy"
            />
        </div>

        <!-- Main content -->
        <div class="tweet-main">
            <!-- Header -->
            <div class="tweet-header">
                <div class="user-info">
                    <span class="username">Zeke Sy</span>
                    <span class="handle">@zekesy</span>
                    <span class="separator">·</span>
                    <time class="timestamp">{formattedDate}</time>
                </div>
            </div>
            
            <!-- Tweet text -->
            <div class="tweet-text">
                <Content />
            </div>

            <!-- Hashtags -->
            {hashtags.length > 0 && (
                <div class="hashtags">
                    {hashtags.map((tag: string) => (
                        <a 
                            href="#" 
                            class="hashtag hashtag-filter"
                            data-hashtag={tag}
                        >
                            #{tag}
                        </a>
                    ))}
                </div>
            )}

            <!-- Tweet actions -->
            <div class="tweet-actions">
                <button class="action-btn comment-btn" aria-label="Comment" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                    </svg>
                    <span class="action-count comment-count">0</span>
                </button>
                
                <button class="action-btn like-btn" aria-label="Like" type="button">
                    <svg class="heart-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                    <span class="action-count like-count">0</span>
                </button>
                
                <button class="action-btn bookmark-btn" aria-label="Bookmark" type="button">
                    <svg class="bookmark-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
                    </svg>
                </button>
                
                <button class="action-btn share-btn" aria-label="Share" type="button">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="18" cy="5" r="3"/>
                        <circle cx="6" cy="12" r="3"/>
                        <circle cx="18" cy="19" r="3"/>
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</article>

<script is:inline>
    (function() {
        function initTweetCards() {
            const cards = document.querySelectorAll('.tweet-card:not([data-initialized])');
            
            console.log('[TweetNote] Found', cards.length, 'uninitalized tweet cards');
            
            cards.forEach(card => {
                card.setAttribute('data-initialized', 'true');
                const noteId = card.dataset.noteId;
                
                if (!noteId) {
                    console.warn('[TweetNote] Card missing noteId');
                    return;
                }
                
                console.log('[TweetNote] Initializing tweet card:', noteId);
                
                const likeBtn = card.querySelector('.like-btn');
                const bookmarkBtn = card.querySelector('.bookmark-btn');
                const shareBtn = card.querySelector('.share-btn');
                const likeCount = card.querySelector('.like-count');
                const heartIcon = card.querySelector('.heart-icon');
                const bookmarkIcon = card.querySelector('.bookmark-icon');
                
                if (!likeBtn || !bookmarkBtn || !shareBtn || !likeCount || !heartIcon || !bookmarkIcon) {
                    console.warn('[TweetNote] Missing elements in card:', noteId);
                    return;
                }
                
                // Load initial state
                try {
                    const likes = JSON.parse(localStorage.getItem('note-likes') || '{}');
                    const bookmarks = JSON.parse(localStorage.getItem('note-bookmarks') || '{}');
                    
                    console.log('[TweetNote] Initial state for', noteId, {
                        liked: likes[noteId],
                        bookmarked: bookmarks[noteId]
                    });
                    
                    // Set like state
                    if (likes[noteId]) {
                        likeBtn.classList.add('liked');
                        heartIcon.style.fill = '#e63946';
                        heartIcon.style.stroke = '#e63946';
                        likeCount.textContent = '1';
                    } else {
                        likeBtn.classList.remove('liked');
                        heartIcon.style.fill = 'none';
                        likeCount.textContent = '0';
                    }
                    
                    // Set bookmark state
                    if (bookmarks[noteId]) {
                        bookmarkBtn.classList.add('bookmarked');
                        bookmarkIcon.style.fill = '#f9a825';
                        bookmarkIcon.style.stroke = '#f9a825';
                    } else {
                        bookmarkBtn.classList.remove('bookmarked');
                        bookmarkIcon.style.fill = 'none';
                    }
                } catch (error) {
                    console.error('[TweetNote] Error loading state:', error);
                }
                
                // Like button handler
                likeBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    console.log('[TweetNote] Like clicked for:', noteId);
                    
                    try {
                        const likes = JSON.parse(localStorage.getItem('note-likes') || '{}');
                        const wasLiked = likes[noteId] === true;
                        
                        console.log('[TweetNote] Current like state:', wasLiked);
                        
                        if (wasLiked) {
                            delete likes[noteId];
                            likeBtn.classList.remove('liked');
                            heartIcon.style.fill = 'none';
                            likeCount.textContent = '0';
                            console.log('[TweetNote] Unliked:', noteId);
                        } else {
                            likes[noteId] = true;
                            likeBtn.classList.add('liked');
                            heartIcon.style.fill = '#e63946';
                            heartIcon.style.stroke = '#e63946';
                            likeCount.textContent = '1';
                            
                            likeBtn.classList.add('heart-pop');
                            setTimeout(() => likeBtn.classList.remove('heart-pop'), 300);
                            console.log('[TweetNote] Liked:', noteId);
                        }
                        
                        localStorage.setItem('note-likes', JSON.stringify(likes));
                        console.log('[TweetNote] Saved likes to localStorage:', likes);
                        
                        window.dispatchEvent(new CustomEvent('notesFilterChange'));
                    } catch (error) {
                        console.error('[TweetNote] Error toggling like:', error);
                    }
                });
                
                // Bookmark button handler
                bookmarkBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    console.log('[TweetNote] Bookmark clicked for:', noteId);
                    
                    try {
                        const bookmarks = JSON.parse(localStorage.getItem('note-bookmarks') || '{}');
                        const wasBookmarked = bookmarks[noteId] === true;
                        
                        console.log('[TweetNote] Current bookmark state:', wasBookmarked);
                        
                        if (wasBookmarked) {
                            delete bookmarks[noteId];
                            bookmarkBtn.classList.remove('bookmarked');
                            bookmarkIcon.style.fill = 'none';
                            console.log('[TweetNote] Unbookmarked:', noteId);
                        } else {
                            bookmarks[noteId] = true;
                            bookmarkBtn.classList.add('bookmarked');
                            bookmarkIcon.style.fill = '#f9a825';
                            bookmarkIcon.style.stroke = '#f9a825';
                            console.log('[TweetNote] Bookmarked:', noteId);
                        }
                        
                        localStorage.setItem('note-bookmarks', JSON.stringify(bookmarks));
                        console.log('[TweetNote] Saved bookmarks to localStorage:', bookmarks);
                        
                        window.dispatchEvent(new CustomEvent('notesFilterChange'));
                    } catch (error) {
                        console.error('[TweetNote] Error toggling bookmark:', error);
                    }
                });
                
                // Share button handler
                shareBtn.addEventListener('click', async function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    
                    const url = window.location.origin + '/notes/' + noteId;
                    
                    if (navigator.share) {
                        try {
                            await navigator.share({
                                title: 'Check out this note',
                                url: url
                            });
                        } catch (err) {
                            console.log('Share cancelled');
                        }
                    } else {
                        navigator.clipboard.writeText(url);
                        
                        const originalHTML = shareBtn.innerHTML;
                        shareBtn.innerHTML = '<span style="font-size: 0.85rem;">✓ Copied!</span>';
                        setTimeout(() => {
                            shareBtn.innerHTML = originalHTML;
                        }, 2000);
                    }
                });
            });
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initTweetCards);
        } else {
            initTweetCards();
        }
        
        document.addEventListener('astro:page-load', initTweetCards);
        setTimeout(initTweetCards, 100);
    })();
</script>

<style>
    .tweet-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 16px;
        transition: all 0.2s ease;
    }

    .tweet-card:hover {
        border-color: #cbd5e1;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    }

    .tweet-content {
        display: flex;
        gap: 12px;
    }

    .avatar-container {
        flex-shrink: 0;
    }

    .avatar {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        object-fit: cover;
    }

    .tweet-main {
        flex: 1;
        min-width: 0;
    }

    .tweet-header {
        margin-bottom: 8px;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.9rem;
        flex-wrap: wrap;
    }

    .username {
        font-weight: 700;
        color: #1a1a1a;
    }

    .handle,
    .timestamp {
        color: #6b7280;
    }

    .separator {
        color: #6b7280;
    }

    .tweet-text {
        margin-bottom: 12px;
        line-height: 1.5;
        color: #1a1a1a;
        word-wrap: break-word;
    }

    .tweet-text :global(p) {
        margin: 0 0 8px 0;
    }

    .tweet-text :global(p:last-child) {
        margin-bottom: 0;
    }

    .hashtags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-bottom: 12px;
    }

    .hashtag {
        color: #667eea;
        font-size: 0.9rem;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .hashtag:hover {
        text-decoration: underline;
        color: #5568d3;
    }

    .tweet-actions {
        display: flex;
        justify-content: space-between;
        max-width: 425px;
        padding-top: 8px;
        border-top: 1px solid #f3f4f6;
        margin-top: 12px;
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        background: none;
        border: none;
        color: #6b7280;
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 6px;
        transition: all 0.2s ease;
    }

    .action-btn:hover {
        background: #f3f4f6;
    }

    .comment-btn:hover {
        color: #667eea;
    }

    .like-btn:hover {
        color: #e63946;
    }

    .like-btn.liked {
        color: #e63946;
    }

    .like-btn:hover .heart-icon,
    .like-btn.liked .heart-icon {
        fill: #e63946;
        stroke: #e63946;
    }

    .bookmark-btn:hover {
        color: #f9a825;
    }

    .bookmark-btn.bookmarked {
        color: #f9a825;
    }

    .bookmark-btn:hover .bookmark-icon,
    .bookmark-btn.bookmarked .bookmark-icon {
        fill: #f9a825;
        stroke: #f9a825;
    }

    .share-btn:hover {
        color: #10b981;
    }

    @keyframes heart-pop {
        0% { transform: scale(1); }
        50% { transform: scale(1.3); }
        100% { transform: scale(1); }
    }

    .like-btn.heart-pop .heart-icon {
        animation: heart-pop 0.3s ease;
    }

    .action-count {
        font-size: 0.85rem;
        font-weight: 500;
    }
</style>