---
// SearchBar.astro
import "../styles/global.css";
---

<div class="search-sidebar">

  <!-- Search Input -->
  <div class="search-field">
    <svg class="search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <circle cx="11" cy="11" r="8"/>
      <path d="m21 21-4.3-4.3"/>
    </svg>
    <input
      type="search"
      id="search-input"
      class="search-input"
      placeholder="Search note titles…"
      autocomplete="off"
    />
    <div class="search-kbd">
      <kbd>⌘</kbd><kbd>K</kbd>
    </div>
  </div>

  <!-- Divider -->
  <div class="sb-divider"></div>

  <!-- View filter tabs -->
  <div class="sb-section">
    <p class="sb-label">View</p>
    <div class="filter-tabs">
      <button class="filter-tab active" data-filter="all">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
        </svg>
        All
        <span class="tab-count" id="all-count">0</span>
      </button>

      <button class="filter-tab" data-filter="liked">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        Liked
        <span class="tab-count" id="liked-count">0</span>
      </button>

      <button class="filter-tab" data-filter="bookmarked">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
        </svg>
        Saved
        <span class="tab-count" id="bookmarked-count">0</span>
      </button>
    </div>
  </div>

  <!-- Divider -->
  <div class="sb-divider"></div>

  <!-- Type filter -->
  <div class="sb-section">
    <p class="sb-label">Type</p>
    <div class="type-options">
      <label class="type-option">
        <input type="radio" name="type-filter-radio" value="all" checked />
        <span>All</span>
      </label>
      <label class="type-option">
        <input type="radio" name="type-filter-radio" value="tweet" />
        <span>Tweet</span>
      </label>
      <label class="type-option">
        <input type="radio" name="type-filter-radio" value="article" />
        <span>Article</span>
      </label>
      <label class="type-option">
        <input type="radio" name="type-filter-radio" value="blog" />
        <span>Blog</span>
      </label>
    </div>
    <!-- hidden select kept for JS compatibility -->
    <select id="type-filter" style="display:none">
      <option value="all">All Types</option>
      <option value="tweet">Tweet</option>
      <option value="article">Article</option>
      <option value="blog">Blog</option>
    </select>
  </div>

  <!-- Divider -->
  <div class="sb-divider"></div>

  <!-- Active hashtag chip -->
  <div id="active-hashtag" class="hidden">
    <div class="sb-section">
      <p class="sb-label">Hashtag</p>
      <div class="hashtag-chip">
        <span id="hashtag-value" class="hashtag-chip-text"></span>
        <button id="remove-hashtag" class="hashtag-chip-remove" aria-label="Remove filter">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M18 6L6 18M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="sb-divider"></div>
  </div>

  <!-- Results count + clear -->
  <div class="sb-footer">
    <span class="results-text"><span id="results-count">0</span> notes</span>
    <button id="clear-filters" class="clear-btn">Clear</button>
  </div>

</div>

<script>
  // Sync radio buttons → hidden select
  document.querySelectorAll('input[name="type-filter-radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      const select = document.getElementById('type-filter') as HTMLSelectElement;
      if (select) select.value = (radio as HTMLInputElement).value;
      select?.dispatchEvent(new Event('change', { bubbles: true }));
    });
  });
</script>

<style>
  .search-sidebar {
    width: 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Search field ── */
  .search-field {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  .search-icon {
    color: #9ca3af;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    min-width: 0;
    border: none;
    background: transparent;
    font-size: 13px;
    color: #111827;
    outline: none;
    font-family: inherit;
  }

  .search-input::placeholder { color: #9ca3af; }

  .search-kbd {
    display: flex;
    gap: 2px;
    flex-shrink: 0;
  }

  .search-kbd kbd {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1px 5px;
    font-size: 10px;
    font-family: inherit;
    color: #9ca3af;
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
  }

  /* ── Section wrapper ── */
  .sb-section {
    padding: 16px 0;
  }

  .sb-label {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #9ca3af;
    margin: 0 0 10px;
  }

  .sb-divider {
    height: 1px;
    background: #f3f4f6;
  }

  /* ── Filter tabs (All / Liked / Saved) ── */
  .filter-tabs {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .filter-tab {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 10px;
    background: transparent;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    color: #374151;
    font-family: inherit;
    text-align: left;
    transition: background 0.15s, color 0.15s;
  }

  .filter-tab:hover { background: #f3f4f6; }

  .tab-count {
    margin-left: auto;
    font-size: 11px;
    font-weight: 600;
    color: #9ca3af;
    background: #f3f4f6;
    border-radius: 999px;
    padding: 1px 7px;
    min-width: 20px;
    text-align: center;
  }

  /* Active states */
  .filter-tab.active { background: #f3f4f6; color: #111827; }
  .filter-tab.active .tab-count { background: #111827; color: white; }
  .filter-tab.active svg { stroke: #111827; }

  .filter-tab[data-filter="liked"].active { background: #fef2f2; color: #dc2626; }
  .filter-tab[data-filter="liked"].active .tab-count { background: #dc2626; color: white; }
  .filter-tab[data-filter="liked"].active svg { stroke: #dc2626; fill: #dc2626; }

  .filter-tab[data-filter="bookmarked"].active { background: #fffbeb; color: #d97706; }
  .filter-tab[data-filter="bookmarked"].active .tab-count { background: #d97706; color: white; }
  .filter-tab[data-filter="bookmarked"].active svg { stroke: #d97706; fill: #d97706; }

  /* ── Type radio options ── */
  .type-options {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .type-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    color: #374151;
    transition: background 0.15s;
  }

  .type-option:hover { background: #f3f4f6; }

  .type-option input[type="radio"] {
    accent-color: #111827;
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    cursor: pointer;
  }

  .type-option input[type="radio"]:checked + span {
    color: #111827;
    font-weight: 600;
  }

  /* ── Active hashtag chip ── */
  .hashtag-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px 4px 12px;
    background: #f3f4f6;
    border-radius: 999px;
    border: 1px solid #e5e7eb;
    max-width: 100%;
  }

  .hashtag-chip-text {
    font-size: 12px;
    font-weight: 600;
    color: #111827;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .hashtag-chip-remove {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border: none;
    background: #e5e7eb;
    border-radius: 50%;
    cursor: pointer;
    color: #6b7280;
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .hashtag-chip-remove:hover { background: #d1d5db; color: #111827; }

  /* ── Footer ── */
  .sb-footer {
    padding: 16px 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .results-text {
    font-size: 12px;
    color: #9ca3af;
  }

  .results-text span {
    font-weight: 600;
    color: #374151;
  }

  .clear-btn {
    font-size: 12px;
    font-weight: 500;
    color: #6b7280;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 4px;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
  }

  .clear-btn:hover { background: #f3f4f6; color: #111827; }
</style>
