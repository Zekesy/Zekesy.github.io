---
import Layout from '../layouts/Layout.astro';
import { ArrowRight } from '@lucide/astro';
import background from '../assets/background.svg';
import '../styles/global.css';
---

<Layout>
  <div class="page">
    <div id="container">
      <img id="background" src={background.src} alt="" fetchpriority="high" />
        <main>
          <section id="hero">
            <h1>Hi I am Zeke Sy ...</h1>
            <section id="links">
              <a href="/home" class="button">
                  <span>More</span>
                  <ArrowRight />
              </a>
            </section>
          </section>
        </main>
    </div>
  </div>
</Layout>

<style>
    #background {
        position: fixed; 
        top: 0; 
        left: 0; 
        width: 100%;
        height: 100%;
        z-index: -1;
        filter: blur(100px);
    }

    #container {
        font-family: Inter, Robot, 'Helvetica Neue', 'Arial Nova', 
        'Nimbus Sans', Arial, sans-serif;
        height: 100%; 
        position: relative;
    }

    main {
        height: 100%;
        display: flex;
        justify-content: center; 
    }

    #hero {
      display: flex; 
      align-items: start; 
      flex-direction: column;
      justify-content: center;
      padding: 16px;
    }
    h1 {
        font-size: 50px; 
        /* em is scale proportionate to direct parent element */
        margin-top: 1em 
    }

    #links a {
      display: flex;
      align-items:center;
      padding: 10px 12px;
      color: #111827;
      text-decoration: none;
      transition: color 0.2s;
    }

    #links a.button{
      color:white;
      background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.12),
        inset 0 -2px 0 rgba(0, 0, 0, 0.24);
      cursor: pointer; 
      border-radius: 10px;
      font-size: 25px; 

    }

    #links a.button:hover{
      color: rgb(230,230,230);
      box-shadow:none;
    }
</style>
