---
import BlogLayout from '../../layouts/BlogLayout.astro';

import { getCollection } from 'astro:content';
const allBlogs = await getCollection("blog");
const tvshows = allBlogs
  .filter(entry => entry.id.startsWith('tvshows/'))
  .map(entry => ({
    title: entry.data.title,
    pubDate: entry.data.pubDate.toLocaleDateString("sv-SE"),
    link: `/blogs/tvshows/${entry.id.replace('tvshows/', '')}`,
    }));


---

<BlogLayout title="TV Shows" bg="#dbeafe">
<div class="max-w-7xl mx-auto px-4">
    <h1 class="text-5xl font-bold text-black mb-8 text-left">TV Shows</h1>
    
    <!-- show Grid -->
    <div class="show-grid mb-12">
      {tvshows.map((show, index) => (
        <a href={show.link} class="show-item">
          <canvas id={`canvas-${index}`} class="show-canvas"></canvas>
          <h3 class="show-title">{show.title}</h3>
          <h4 class="show-date">{show.pubDate}</h4>
        </a>
      ))}
    </div>
  </div>

  <style>
    .show-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 2rem;
      margin-bottom: 1rem;
    }

    @media (max-width: 1024px) {
      .show-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 640px) {
      .show-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .show-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .show-item:hover {
      transform: scale(1.1);
    }

    .show-item:hover .show-title {
      color: #ffffff;
    }

    .show-canvas {
      width: 100%;
      aspect-ratio: 1;
      background: transparent;
    }

    .show-title {
      font-size: 1rem;
      font-weight: 600;
      color: #333;
      text-align: center;
      margin: 0;
      margin-top: 0rem;
      transition: color 0.3s ease;
    }
  </style>

  <script type="module">
    import { Renderer3D } from "/src/scripts/rendering.js";
    import { triangulate, parseOBJ, normalizeMesh } from "/src/scripts/mesh.js";

    window.addEventListener("DOMContentLoaded", async () => {
      try {
        // Fetch the OBJ file
        const response = await fetch('/src/assets/models/katara.obj');
        //const response = await fetch('/src/assets/models/spinningTop.obj');
        if (!response.ok) {
          throw new Error(`Failed to load OBJ file: ${response.status}`);
        }
        
        const objContent = await response.text();
        
        // Parse and prepare the mesh
        const parsedMesh = parseOBJ(objContent);
        const normalizedMesh = normalizeMesh(parsedMesh, 2.5);
        const clapperMesh = triangulate(normalizedMesh);

        console.log('Loaded clapperboard:', clapperMesh); // Debug

        const FPS = 30;
        const showCanvases = document.querySelectorAll('[id^="canvas-"]');

        showCanvases.forEach((canvas, index) => {
          const canvasId = canvas.id;
          const renderer = new Renderer3D(canvasId);
          
          let showAngle = index * 0.3;
          let uprightAngle = -Math.PI / 2;
          function animateshow() {
            const dt = 1 / FPS;
            showAngle += Math.PI * dt * 0.7;
            
            renderer.clear({r: 0, g: 0, b: 0, a: 0});
            
            renderer.render(clapperMesh, {
              rotation: {x: uprightAngle , y: showAngle, z: 0},
              translation: {x: 0, y: 0, z: 6},
              scale: 1
            });
            
            requestAnimationFrame(animateshow); // Smoother than setTimeout
          }
          
          animateshow();
        });
        
      } catch (error) {
        console.error('Error loading clapperboard model:', error);
      }
    }); 
  </script>


</BlogLayout>
