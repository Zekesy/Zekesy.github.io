---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';

const allBlogs = await getCollection('blog');
console.log(allBlogs);
const movies = allBlogs
  .filter(entry => entry.id.startsWith('movies/'))
  .map(entry => ({
    title: entry.data.title,
    link: `/blogs/movies/${entry.id.replace('movies/', '')}`,
    }));

---

<BlogLayout title="Movies" bg="#dbeafe">
  <div class="max-w-7xl mx-auto px-4">
    <h1 class="text-5xl font-bold text-black mb-8 text-left">Movies</h1>
    
    <!-- Movie Grid -->
    <div class="movie-grid mb-12">
      {movies.map((movie, index) => (
        <a href={movie.link} class="movie-item">
          <canvas id={`canvas-${index}`} class="movie-canvas"></canvas>
          <h3 class="movie-title">{movie.title}</h3>
        </a>
      ))}
    </div>
  </div>

  <style>
    .movie-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 2rem;
      margin-bottom: 1rem;
    }

    @media (max-width: 1024px) {
      .movie-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 640px) {
      .movie-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .movie-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .movie-item:hover {
      transform: scale(1.1);
    }

    .movie-item:hover .movie-title {
      color: #ffffff;
    }

    .movie-canvas {
      width: 100%;
      aspect-ratio: 1;
      background: transparent;
    }

    .movie-title {
      font-size: 1rem;
      font-weight: 600;
      color: #333;
      text-align: center;
      margin: 0;
      margin-top: 0rem;
      transition: color 0.3s ease;
    }
  </style>

  <script type="module">
    import { Renderer3D } from "/src/scripts/rendering.js";
    import { triangulate, parseOBJ, normalizeMesh } from "/src/scripts/mesh.js";
    import { createClapperboard, createStripedClapperboard} from "/src/scripts/shapes.js";
  
    window.addEventListener("DOMContentLoaded", async () => {
      try {
        // Fetch the OBJ file
        const response = await fetch('/src/assets/models/clapperboard.obj');

        if (!response.ok) {
          throw new Error(`Failed to load OBJ file: ${response.status}`);
        }
        
        const objContent = await response.text();
        
        // Parse and prepare the mesh
        const parsedMesh = parseOBJ(objContent);
        const normalizedMesh = normalizeMesh(parsedMesh, 2.5);
        const clapperMesh = triangulate(normalizedMesh);

        console.log('Loaded clapperboard:', clapperMesh); // Debug

        const FPS = 30;
        const movieCanvases = document.querySelectorAll('[id^="canvas-"]');

        movieCanvases.forEach((canvas, index) => {
          const canvasId = canvas.id;
          const renderer = new Renderer3D(canvasId);
          
          let movieAngle = index * 0.3;
          let uprightAngle = -Math.PI / 2;
          function animateMovie() {
            const dt = 1 / FPS;
            movieAngle += Math.PI * dt * 0.7;
            
            renderer.clear({r: 0, g: 0, b: 0, a: 0});
            
            renderer.render(clapperMesh, {
              rotation: {x: uprightAngle , y: movieAngle, z: 0},
              translation: {x: 0, y: 0, z: 6},
              scale: 1
            });
            
            requestAnimationFrame(animateMovie); // Smoother than setTimeout
          }
          
          animateMovie();
        });
        
      } catch (error) {
        console.error('Error loading clapperboard model:', error);
      }
    }); 
  </script>
</BlogLayout>
