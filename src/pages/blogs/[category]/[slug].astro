---
import { getCollection, render } from 'astro:content';
import BlogContentLayout from '../../../layouts/BlogContentLayout.astro';

export async function getStaticPaths() {
  const allBlogs = await getCollection('blog');

  return allBlogs.map(entry => {
    // entry.id is like "movies/30DaysOfnight" or "books/Dune"
    const parts = entry.id.split('/');
    const category = parts[0];
    const slug = parts[1];

    return {
      params: { category, slug },
      props: { entry },
    };
  });
}
const { category, slug } = Astro.params;
const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BlogContentLayout title={entry.data.title} color="#dbeafe">
  <div class="max-w-7xl mx-auto px-4 py-8">
    <a href={`/blogs/${category}`} class="back-btn">← Back to Movies</a>
    <h1 class="text-4xl font-bold mt-6 mb-2">{entry.data.title}</h1>
    <p class="text-sm text-gray-500 mb-2">
      {entry.data.pubDate.toLocaleDateString()}
    </p>
    <article class="prose">
      <Content />
    </article>
    <h2 class="text-xl font-bold mt-4 mb-8">Rating: {entry.data.rating} / 10</h2>
  </div>
</BlogContentLayout>

<style>
  .back-btn {
    display: inline-block;
    font-weight: 600;
    color: #555;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .back-btn:hover {
    color: #000;
  }
  .prose {
    line-height: 1.75;
    color: #333;
  }
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
  }
  .prose p {
    margin-bottom: 1rem;
  }
</style>
