---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getCollection } from 'astro:content';
const allBlogs = await getCollection("blog");
const music = allBlogs
  .filter(entry => entry.id.startsWith('music/'))
  .map(entry => ({
    title: entry.data.title,
    pubDate: entry.data.pubDate.toLocaleDateString("sv-SE"),
    link: `/blogs/music/${entry.id.replace('music/', '')}`,
    }));

---

<BlogLayout title="Music" bg="#dbeafe">
    <h1 class="text-5xl font-bold text-black mb-8 text-left">Music</h1>
    <div class="w-[80%] mx-auto">
    <!-- song Grid -->
    <div class="song-grid mb-12">
      {music.map((song, index) => (
        <a href={song.link} class="song-item">
          <canvas id={`canvas-${index}`} class="song-canvas"></canvas>
          <h3 class="song-title">{song.title}</h3>
          <h4 class="song-date">{song.pubDate}</h4>
        </a>
      ))}
    </div>
    </div>
  <style>
    .song-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 2rem;
      margin-bottom: 1rem;
    }

    @media (max-width: 1024px) {
      .song-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 640px) {
      .song-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .song-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-decoration: none;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .song-item:hover {
      transform: scale(1.1);
    }

    .song-item:hover .song-title {
      color: #333;
    }

    .song-canvas {
      width: 100%;
      aspect-ratio: 1;
      background: transparent;
    }

    .song-title {
      font-size: 1rem;
      font-weight: 600;
      color: #333;
      text-align: center;
      margin: 0;
      margin-top: 0rem;
      transition: color 0.3s ease;
    }
  </style>

  <script type="module">
    import { Renderer3D } from "/src/scripts/rendering.js";
    import { triangulate, parseOBJ, normalizeMesh, loadMeshJSON } from "/src/scripts/mesh.js";

    window.addEventListener("DOMContentLoaded", async () => {
      try {
        // Fetch the OBJ file
        // const response = await fetch('/src/assets/models/sax.obj');
        //const response = await fetch('/src/assets/models/spinningTop.obj');
        // Parse and prepare the mesh
        // const parsedMesh = parseOBJ(objContent);
        // const normalizedMesh = normalizeMesh(parsedMesh, 2.5);
        // const clapperMesh = triangulate(normalizedMesh);

        const mesh = await loadMeshJSON('/src/assets/sax.json'); 
        const FPS = 15;
        const songCanvases = document.querySelectorAll('[id^="canvas-"]');

        songCanvases.forEach((canvas, index) => {
          const canvasId = canvas.id;
          const renderer = new Renderer3D(canvasId);
          
          let songAngle = index * 0.3;
          let uprightAngle = -Math.PI / 2;
          function animatesong() {
            const dt = 1 / FPS;
            songAngle += Math.PI * dt * 0.2;
            
            renderer.clear({r: 0, g: 0, b: 0, a: 0});
            
            renderer.render(mesh, {
              rotation: {x: uprightAngle , y: songAngle, z: 0},
              translation: {x: 0, y: 0, z: 6},
              scale: 1
            });
            
            requestAnimationFrame(animatesong); // Smoother than setTimeout
          }
          
          animatesong();
        });
        
      } catch (error) {
        console.error('Error loading clapperboard model:', error);
      }
    }); 
  </script>



</BlogLayout>
