<script>
  const trigger = document.getElementById('contact-trigger');
  const dropdown = document.getElementById('contact-dropdown');
  const scrollLink = document.getElementById('scroll-to-contact');

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = dropdown?.hidden;
    if (dropdown) dropdown.hidden = !isHidden;
    trigger.setAttribute('aria-expanded', String(isHidden));
    trigger.classList.toggle('open', isHidden ?? false);
  });

  document.addEventListener('click', (e) => {
    const fab = document.getElementById('contact-fab');
    if (dropdown && !dropdown.hidden && !fab?.contains(e.target as Node)) {
      dropdown.hidden = true;
      trigger?.classList.remove('open');
      trigger?.setAttribute('aria-expanded', 'false');
    }
  });

  dropdown?.addEventListener('click', e => e.stopPropagation());
  scrollLink?.addEventListener('click', (e) => {
    e.preventDefault();
    if (dropdown) dropdown.hidden = true;
    trigger?.classList.remove('open');
    document.getElementById('contact-me')?.scrollIntoView({ behavior: 'smooth' });
  });
</script>

