---
import "../../styles/global.css";
import AboutNavbar from "../../components/about/AboutNavbar.astro";
import Layout from '../../layouts/Layout.astro';
---

<Layout>
  <AboutNavbar />

  <main id="about-page">

    <!-- ═══════════════════════════════════════════
         ABOUT ME
    ════════════════════════════════════════════ -->
    <section id="about-me">
      <div class="section-inner about-grid">
        <div class="about-photo-col">
          <div class="photo-frame">
            <img src="/images/profile.jpg" alt="Profile Photo" />
          </div>
          <div class="qualifications-badges">
            <span class="badge">TOEIC 990</span>
            <span class="badge">JLPT N2</span>
          </div>
        </div>

        <div class="about-info-col">
          <p class="section-label">About Me</p>
          <h1 class="name-heading">Your Full Name</h1>

          <div class="info-grid">
            <div class="info-item">
              <span class="info-key">Age</span>
              <span class="info-val">XX</span>
            </div>
            <div class="info-item">
              <span class="info-key">Nationality</span>
              <span class="info-val">Your Nationality</span>
            </div>
            <div class="info-item">
              <span class="info-key">Residence</span>
              <span class="info-val">Japan</span>
            </div>
            <div class="info-item">
              <span class="info-key">Status</span>
              <span class="info-val employed">Employed · Researcher</span>
            </div>
            <div class="info-item full-width">
              <span class="info-key">Qualifications</span>
              <span class="info-val">
                B.Eng &amp; M.Eng, Computer Science and Engineering<br/>
                <span class="uni">University of Aizu, Japan</span>
              </span>
            </div>
            <div class="info-item">
              <span class="info-key">TOEIC</span>
              <span class="info-val score">990 / 990</span>
            </div>
            <div class="info-item">
              <span class="info-key">JLPT</span>
              <span class="info-val score">N2</span>
            </div>
          </div>

          <p class="bio">
            I'm a computer science and engineering researcher specializing in computer vision,
            neural radiance fields (NeRF), sim-to-real robotic transfer, and semantic
            communication networks. My work bridges deep learning theory with
            real-world robotic deployment, using tools like NVIDIA Isaac Sim and Isaac Lab
            to close the gap between simulation and physical systems.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         RESEARCH INTERESTS
    ════════════════════════════════════════════ -->
    <section id="research-interests">
      <div class="section-inner">
        <p class="section-label">What I Work On</p>
        <h2 class="section-heading">Research Interests</h2>
        <div class="interests-grid">
          <div class="interest-card">
            <div class="interest-icon">◈</div>
            <h3>Neural Radiance Fields</h3>
            <p>3D scene reconstruction and novel view synthesis using implicit neural representations. Exploring real-time NeRF variants and their applications in robotic perception.</p>
          </div>
          <div class="interest-card">
            <div class="interest-icon">◎</div>
            <h3>Sim-to-Real Robotics</h3>
            <p>Bridging the reality gap using domain randomization, physics-based simulation in NVIDIA Isaac Sim / Isaac Lab, and robust policy transfer to physical robotic systems.</p>
          </div>
          <div class="interest-card">
            <div class="interest-icon">◉</div>
            <h3>Computer Vision Semantics</h3>
            <p>Semantic scene understanding, segmentation, and 3D object detection for autonomous systems operating in unstructured environments.</p>
          </div>
          <div class="interest-card">
            <div class="interest-icon">◐</div>
            <h3>Semantic Communication</h3>
            <p>Task-oriented communication systems that transmit meaning rather than raw bits, leveraging deep learning for joint source-channel coding in constrained networks.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         EDUCATION
    ════════════════════════════════════════════ -->
    <section id="education">
      <div class="section-inner">
        <p class="section-label">Academic Background</p>
        <h2 class="section-heading">Education</h2>
        <div class="edu-list">
          <div class="edu-item">
            <div class="edu-meta">
              <span class="edu-year">2022 – 2024</span>
              <span class="edu-degree">Master of Engineering</span>
            </div>
            <div class="edu-body">
              <h3>Computer Science and Engineering</h3>
              <p class="edu-uni">University of Aizu, Aizuwakamatsu, Japan</p>
              <p class="edu-thesis">
                <span class="thesis-label">Thesis:</span>
                "Your Master's Thesis Title Here" — brief one-sentence description of the contribution.
              </p>
            </div>
          </div>
          <div class="edu-item">
            <div class="edu-meta">
              <span class="edu-year">2018 – 2022</span>
              <span class="edu-degree">Bachelor of Engineering</span>
            </div>
            <div class="edu-body">
              <h3>Computer Science and Engineering</h3>
              <p class="edu-uni">University of Aizu, Aizuwakamatsu, Japan</p>
              <p class="edu-thesis">
                <span class="thesis-label">Thesis:</span>
                "Your Undergraduate Thesis Title Here" — brief one-sentence description of the contribution.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         EXPERIENCE TIMELINE
    ════════════════════════════════════════════ -->
    <section id="experience">
      <div class="section-inner">
        <p class="section-label">Career</p>
        <h2 class="section-heading">Experience</h2>
        <div class="timeline">
          <div class="timeline-line"></div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="tl-date">2024 – Present</span>
              <h3 class="tl-role">Research Engineer / Position Title</h3>
              <p class="tl-org">Organization Name · City, Japan</p>
              <p class="tl-desc">
                Describe your responsibilities and achievements. Focus on technical contributions:
                tools used, systems built, papers contributed to, or teams led.
              </p>
              <div class="tl-tags">
                <span>Isaac Sim</span><span>NeRF</span><span>Python</span><span>ROS2</span>
              </div>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="tl-date">2022 – 2024</span>
              <h3 class="tl-role">Graduate Research Assistant</h3>
              <p class="tl-org">University of Aizu · Aizuwakamatsu, Japan</p>
              <p class="tl-desc">
                Conducted research on [your topic]. Developed [system/method]. Published [X] papers
                and presented work at [conferences]. Supervised undergraduate student projects.
              </p>
              <div class="tl-tags">
                <span>Computer Vision</span><span>Deep Learning</span><span>PyTorch</span>
              </div>
            </div>
          </div>

          <div class="timeline-item">
            <div class="timeline-dot"></div>
            <div class="timeline-content">
              <span class="tl-date">2020 – 2022</span>
              <h3 class="tl-role">Undergraduate Research Student</h3>
              <p class="tl-org">University of Aizu · Aizuwakamatsu, Japan</p>
              <p class="tl-desc">
                Joined [Lab Name] lab and worked on undergraduate thesis project exploring
                [topic]. Gained hands-on experience with [tools/systems].
              </p>
              <div class="tl-tags">
                <span>C++</span><span>OpenCV</span><span>Linux</span>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         PUBLICATIONS
    ════════════════════════════════════════════ -->
    <section id="publications">
      <div class="section-inner">
        <p class="section-label">Research Output</p>
        <h2 class="section-heading">Publications</h2>
        <div class="pub-list">

          <div class="pub-item">
            <span class="pub-year">2024</span>
            <div class="pub-body">
              <p class="pub-title">Your Paper Title: A Study of Something Important</p>
              <p class="pub-authors"><strong>Your Name</strong>, Co-Author Name, Co-Author Name</p>
              <p class="pub-venue">Conference / Journal Name, City, Year</p>
              <div class="pub-links">
                <a href="#" class="pub-link">Paper ↗</a>
                <a href="#" class="pub-link">arXiv ↗</a>
                <a href="#" class="pub-link">Code ↗</a>
              </div>
            </div>
          </div>

          <div class="pub-item">
            <span class="pub-year">2023</span>
            <div class="pub-body">
              <p class="pub-title">Another Paper Title: More Research Contributions</p>
              <p class="pub-authors"><strong>Your Name</strong>, Co-Author Name</p>
              <p class="pub-venue">Conference / Journal Name, City, Year</p>
              <div class="pub-links">
                <a href="#" class="pub-link">Paper ↗</a>
                <a href="#" class="pub-link">arXiv ↗</a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         SKILLS
    ════════════════════════════════════════════ -->
    <section id="skills">
      <div class="section-inner">
        <p class="section-label">Technical Proficiency</p>
        <h2 class="section-heading">Skills</h2>
        <div class="skills-grid">
          <div class="skill-group">
            <h3>Languages</h3>
            <div class="skill-tags">
              <span>Python</span><span>C++</span><span>CUDA</span>
              <span>Bash</span><span>JavaScript</span>
            </div>
          </div>
          <div class="skill-group">
            <h3>Frameworks &amp; Libraries</h3>
            <div class="skill-tags">
              <span>PyTorch</span><span>TensorFlow</span><span>OpenCV</span>
              <span>ROS / ROS2</span><span>Open3D</span>
            </div>
          </div>
          <div class="skill-group">
            <h3>Simulation &amp; Tools</h3>
            <div class="skill-tags">
              <span>NVIDIA Isaac Sim</span><span>Isaac Lab</span>
              <span>Blender</span><span>Docker</span><span>Git</span>
            </div>
          </div>
          <div class="skill-group">
            <h3>Languages (Human)</h3>
            <div class="skill-tags">
              <span>English — Native/Fluent (TOEIC 990)</span>
              <span>Japanese — Intermediate (JLPT N2)</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════
         PROJECTS
    ════════════════════════════════════════════ -->
    <section id="projects">
      <div class="section-inner">
        <p class="section-label">Selected Work</p>
        <h2 class="section-heading">Projects</h2>
        <div class="projects-grid">

          <div class="project-card">
