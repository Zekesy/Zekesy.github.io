            <div class="about-info-col">
              <p class="section-label">About Me</p>
              <h1 class="name-heading">Your Full Name</h1>

              <div class="info-grid">
                <div class="info-item">
                  <span class="info-key">Age</span>
                  <span class="info-val">{new Date().getFullYear() - 2001 - (new Date() < new Date(new Date().getFullYear(), 11, 8) ? 1 : 0)}</span>
